; impit (a transitive dep of camoufox-js) ships a preinstall script that
; runs `npx only-allow pnpm` and exits non-zero under npm. We use npm for
; this worker, so skip install scripts. Patchright, playwright, and
; camoufox-js have no install scripts (binaries are fetched manually via
; the install:browsers / install:camoufox scripts), so this is safe.
ignore-scripts=true
