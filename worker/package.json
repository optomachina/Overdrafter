{
  "name": "overdrafter-cad-worker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "start:prod": "node dist/index.js",
    "check": "tsc --noEmit",
    "auth:xometry": "tsx src/tools/xometryAuth.ts",
    "import:quotes": "tsx src/tools/importSpreadsheetQuotes.ts",
    "install:browsers": "playwright install chromium"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "@supabase/supabase-js": "^2.77.0",
    "fast-xml-parser": "^5.2.5",
    "node-stream-zip": "^1.15.0",
    "openai": "^4.104.0",
    "playwright": "^1.52.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
